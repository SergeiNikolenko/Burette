  "identifier": "default",
  "description": "Minimal permissions for the Burrete desktop shell",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "dialog:allow-open",
    "opener:allow-open-path",
    "allow-viewer-commands"
  ]
}
