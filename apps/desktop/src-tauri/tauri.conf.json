{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Burrete",
  "version": "0.10.27",
  "identifier": "com.local.BurreteV10",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Burrete",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 20,
          "y": 24
        },
        "transparent": true,
        "windowEffects": {
          "effects": [
            "hudWindow"
          ],
          "state": "active"
        },
        "decorations": true,
        "width": 1180,
        "height": 760,
        "minWidth": 820,
        "minHeight": 520,
        "visible": true,
        "backgroundColor": "#00000000"
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: http://asset.localhost; connect-src ipc: http://ipc.localhost https://api.github.com; script-src 'self' asset: http://asset.localhost; style-src 'self' asset: http://asset.localhost; img-src 'self' data: asset: http://asset.localhost; frame-src 'self' asset: http://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPCACHE/**",
          "$RESOURCE/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "resources": {
      "../../../PreviewExtension/Web": "Web"
    },
    "macOS": {
      "minimumSystemVersion": "12.0",
      "hardenedRuntime": false
    },
    "fileAssociations": [
      {
        "ext": [
          "pdb",
          "ent",
          "pdbqt",
          "pqr",
          "cif",
          "mcif",
          "mmcif",
          "bcif",
          "sdf",
          "sd",
          "smi",
          "smiles",
          "csv",
          "tsv",
          "mol",
          "mol2",
          "xyz",
          "gro",
          "cub",
          "cube",
          "vasp"
        ],
        "role": "Viewer"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
